##############################################
# JAVA / MAVEN (Spring Boot)
##############################################
/target/
target/
*/target/

# Ignore Java build bin *inside target ONLY*
target/bin/
*/target/bin/

# DO NOT IGNORE ROOT /bin (your scripts)
!/bin/
!/bin/**

*.class
*.jar
*.war
*.iml
*.log
*.out

##############################################
# PYTHON (AI Modules)
##############################################
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/

# Python environments
env/
venv/
.venv/
python_env/
*.spec

# Auto-generated AI models
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.sav
*.npy
*.npz

##############################################
# AUTO-GENERATED JSON
##############################################
potholes_data.json
road_data.json
dashboard_data.json

##############################################
