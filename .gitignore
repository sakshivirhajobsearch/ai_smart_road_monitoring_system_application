##############################################
/data/captured_images/
data/*.csv
data/*.xlsx
/data/reports/*
sensor_log.csv
sensor_log.xlsx

##############################################
# OS / IDE FILES
##############################################
.vscode/
.idea/
Thumbs.db
.DS_Store

##############################################
# LOGS & TEMP
##############################################
*.log
logs/
debug.log
nohup.out
tmp/
temp/
cache/
*.tmp
*.bak
*.orig

##############################################
# SCRIPTS / BATCH EXCLUSIONS
##############################################
